# Environment variables for the application

# NEXT_APP_URL: The base path for the application. This is the prefix for all routes in the application.
NEXT_APP_URL=/gui

# NEXT_API_URL: The root URL for the API. This is the base URL for all API requests.
NEXT_API_URL=http://api:5000/istsos4/v1.1

# AUTHORIZATION: A flag to enable or disable authorization in the application. Set to 1 to enable, 0 to disable.
AUTHORIZATION=0

# NETWORK: A flag to enable or disable network features in the application. Set to 1 to enable, 0 to disable.
NETWORK=1