# Environment variables for the application

# NEXT_APP_URL: The base path for the application. This is the prefix for all routes in the application.
NEXT_APP_URL=/gui

# NEXT_PUBLIC_ISTSOS4_URL: The URL for the ISTSOS4 service. This is used to connect to the ISTSOS4 API for time series data.
NEXT_PUBLIC_ISTSOS4_URL=http://api:5000/v4/v1.1

# NEXT_PUBLIC_MAP_CENTER: The default center coordinates for the map. This is used to set the initial view of the map.
NEXT_PUBLIC_MAP_CENTER=45.7489, 21.2087

# NEXT_PUBLIC_MAP_ZOOM: The default zoom level for the map. This is used to set the initial zoom level of the map.
NEXT_PUBLIC_MAP_ZOOM=10

# NEXT_PUBLIC_MAP_DEFAULT_BASEMAP: The default basemap for the map. This is used to set the initial basemap of the map.
NEXT_PUBLIC_MAP_DEFAULT_BASEMAP=pixelColor