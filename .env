# Environment variables for the application

# NEXT_APP_URL: The base path for the application. This is the prefix for all routes in the application.
NEXT_APP_URL=/gui

# NEXT_PUBLIC_ISTSOS4_URL: The URL for the ISTSOS4 service. This is used to connect to the ISTSOS4 API for time series data.
NEXT_PUBLIC_ISTSOS4_URL=https://hydromet.supsi.ch/tsdb/v1.1